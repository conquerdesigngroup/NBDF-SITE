# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# Formspree form endpoint ID — get it from https://formspree.io/forms
# (Forms → New Form → copy the path segment after /f/, e.g. "xyzabcde")
# Public is fine here: this ID is meant to be exposed in client-side code.
NEXT_PUBLIC_FORMSPREE_FORM_ID=
